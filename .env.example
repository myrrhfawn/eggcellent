# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=0
# Allowed hosts. "*" means any (handy for dev and access via local/Tailscale IP).
# For production set explicit domains/IPs, e.g.:
# ALLOWED_HOSTS=eggcellent.school,100.64.1.5
ALLOWED_HOSTS=*
# To log into /admin via IP (not localhost), add your origin with scheme here,
# e.g.: http://100.64.1.5
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# CORS (the frontend goes through the same nginx, so usually not needed)
CORS_ALLOW_ALL=0

# Seed demo data on first start (1/0)
SEED_DEMO=1

# Admin superuser (created once if it does not exist yet)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin12345
DJANGO_SUPERUSER_EMAIL=eggcellent.online.school@gmail.com

# Port the site (nginx) listens on
WEB_PORT=80

# SQLite database path inside the container.
# Keep it under /app/data — that's the directory bind-mounted to ./data on the host.
SQLITE_PATH=/app/data/db.sqlite3

# --- HTTPS / TLS ---
# Master switch: 0 = HTTP only (no certs needed), 1 = HTTPS (auto-issues on `up`).
ENABLE_HTTPS=0
# Domain(s) of the site — space-separated; the FIRST one is the cert name.
SERVER_NAME=example.com www.example.com
# Email for Let's Encrypt (expiry notices)
LETSENCRYPT_EMAIL=you@example.com
# Host directory holding the certs (certbot config dir; mounted into nginx).
CERTS_DIR=/data/certs
# Cert paths INSIDE the container (under /etc/nginx/certs == CERTS_DIR).
# Let's Encrypt layout: live/<first-domain>/{fullchain,privkey}.pem
SSL_CERT=/etc/nginx/certs/live/example.com/fullchain.pem
SSL_KEY=/etc/nginx/certs/live/example.com/privkey.pem

# --- Telegram bot ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=
# Shared secret bot <-> backend (X-Bot-Secret). Generate: python -c "import secrets;print(secrets.token_hex(24))"
BOT_API_SECRET=
# Password for the hidden /admin command inside the bot
BOT_ADMIN_PASSWORD=change-me
